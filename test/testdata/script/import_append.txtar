# Import into an existing bb.cue should append and preserve existing content
# including comments.
exec bbcue import extra.json
stderr 'imported extra.json'
cmp bb.cue expected_bb.cue

-- bb.cue --
// This is a hand-written comment that should be preserved.
bbcue: "settings.yaml": {
	content: {
		key: "value"
	}
}

-- extra.json --
{"new": true}

-- expected_bb.cue --
// This is a hand-written comment that should be preserved.
bbcue: "settings.yaml": {
	content: {
		key: "value"
	}
}

bbcue: "extra.json": content: new: true
