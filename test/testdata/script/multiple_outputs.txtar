exec bbcue
cmp a.json expected_a.json
cmp b.yaml expected_b.yaml
cmp c.toml expected_c.toml

-- bb.cue --
bbcue: "a.json": {
	content: { x: 1 }
}
bbcue: "b.yaml": {
	content: { y: 2 }
}
bbcue: "c.toml": {
	content: { z: 3 }
}

-- expected_a.json --
{
  "x": 1
}
-- expected_b.yaml --
# Generated by bbcue. DO NOT EDIT.

"y": 2
-- expected_c.toml --
# Generated by bbcue. DO NOT EDIT.

z = 3
