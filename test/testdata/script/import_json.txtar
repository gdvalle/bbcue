# Import a JSON file into bb.cue.
exec bbcue import config.json
stderr 'imported config.json'
cmp bb.cue expected_bb.cue

-- config.json --
{
  "host": "localhost",
  "port": 5432,
  "debug": true
}

-- expected_bb.cue --
bbcue: "config.json": content: {
	host:  "localhost"
	port:  5432
	debug: true
}
