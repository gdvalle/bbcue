# By default, bbcue should NOT recurse into subdirectories.
exec bbcue gen .
cmp root.json expected_root.json
! exists nested/pkg/sub.yaml

# --recurse should process subdirectories.
rm root.json
exec bbcue gen --recurse .
cmp root.json expected_root.json
cmp nested/pkg/sub.yaml expected_sub.yaml

# -r is the short form of --recurse.
rm root.json
rm nested/pkg/sub.yaml
exec bbcue gen -r .
cmp root.json expected_root.json
cmp nested/pkg/sub.yaml expected_sub.yaml

# --no-recurse overrides --recurse when both are given.
rm root.json
rm nested/pkg/sub.yaml
exec bbcue gen --recurse --no-recurse .
cmp root.json expected_root.json
! exists nested/pkg/sub.yaml

# -R is the short form of --no-recurse.
rm root.json
exec bbcue gen -r -R .
cmp root.json expected_root.json
! exists nested/pkg/sub.yaml

-- bb.cue --
bbcue: "root.json": {
	content: { level: "root" }
}

-- nested/pkg/bb.cue --
bbcue: "sub.yaml": {
	content: { level: "sub" }
}

-- expected_root.json --
{
  "level": "root"
}
-- expected_sub.yaml --
# Generated by bbcue. DO NOT EDIT.

level: sub
