# Import a TOML file into bb.cue.
exec bbcue import config.toml
stderr 'imported config.toml'
cmp bb.cue expected_bb.cue

-- config.toml --
title = "Example"

[database]
server = "192.168.1.1"
ports = [8001, 8001, 8002]

-- expected_bb.cue --
bbcue: "config.toml": content: {
	title: "Example"
	database: {
		server: "192.168.1.1"
		ports: [8001, 8001, 8002]
	}
}
