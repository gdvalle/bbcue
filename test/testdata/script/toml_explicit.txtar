exec bbcue
cmp config.toml expected_config.toml

-- bb.cue --
bbcue: "config.toml": {
	format: "toml"
	content: {
		title: "My Config"
		database: {
			server: "192.168.1.1"
			port:   5432
		}
	}
}

-- expected_config.toml --
# Generated by bbcue. DO NOT EDIT.

title = 'My Config'

[database]
port = 5432
server = '192.168.1.1'
