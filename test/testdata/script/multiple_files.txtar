exec bbcue -r
cmp root.json expected_root.json
cmp nested/pkg/sub.yaml expected_sub.yaml

-- bb.cue --
bbcue: "root.json": {
	content: { level: "root" }
}

-- nested/pkg/bb.cue --
bbcue: "sub.yaml": {
	content: { level: "sub" }
}

-- expected_root.json --
{
  "level": "root"
}
-- expected_sub.yaml --
# Generated by bbcue. DO NOT EDIT.

level: sub
